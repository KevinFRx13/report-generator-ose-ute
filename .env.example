# ── OpenRouter API (free tier) ─────────────────────────────────────────────
# Create a free account and API key at https://openrouter.ai/keys
# No credit card required for free models
OPENROUTER_API_KEY=sk-or-v1-...

# ── Microsoft Graph API (Outlook / Microsoft 365) ──────────────────────────
# Register an app in Azure AD:
#   1. Go to https://portal.azure.com → Azure Active Directory → App registrations → New registration
#   2. Name it (e.g. "report-generator-ose-ute"), choose "Accounts in this org only"
#   3. Under "API permissions" add:
#        Microsoft Graph → Application permissions → Mail.Read  (to read incoming bills)
#        Microsoft Graph → Application permissions → Mail.Send  (to send the report)
#   4. Click "Grant admin consent"
#   5. Under "Certificates & secrets" create a new Client secret → copy value below
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here

# Outlook mailbox where OSE/UTE bills arrive (used for automatic fetching)
BILLS_MAILBOX=facturas@tuempresa.com.uy

# ── Email distribution ─────────────────────────────────────────────────────
# Comma-separated list of recipients for the monthly report
REPORT_RECIPIENTS=gerencia@tuempresa.com.uy,contabilidad@tuempresa.com.uy

# "From" address (must be a mailbox in your Microsoft 365 tenant)
REPORT_SENDER=reportes@tuempresa.com.uy

# ── Email senders to search for bills ─────────────────────────────────────
# Comma-separated list — emails from these addresses with PDF attachments
# will be treated as utility bills
OSE_EMAIL_SENDER=noreply@ose.com.uy
UTE_EMAIL_SENDER=ute@ute.com.uy

# ── Local storage ──────────────────────────────────────────────────────────
# Path to the SQLite database (relative to project root)
DB_PATH=data/bills.db

# Folder where downloaded/processed PDFs are stored
BILLS_FOLDER=data/bills
